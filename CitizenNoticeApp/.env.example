# Mobile App Environment Configuration
# Copy this file to .env and fill in your actual values

# ==================== API CONFIGURATION ====================
# Backend API URL - Used by the mobile app to communicate with the backend
#
# For development:
# - Local machine: EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
# - Physical device (same network): EXPO_PUBLIC_API_BASE_URL=http://YOUR_COMPUTER_IP:3000
# - Android Emulator: EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3000
# - iOS Simulator: EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
#
# For production:
# - EXPO_PUBLIC_API_BASE_URL=https://your-api-domain.com
#
EXPO_PUBLIC_API_BASE_URL=http://192.168.31.219:3000
