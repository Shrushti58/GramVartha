# Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# ==================== DATABASE ====================
MONGODB_URL=mongodb://localhost:27017/gramvartha

# ==================== API SERVER ====================
PORT=3000
NODE_ENV=development

# ==================== CORS ORIGINS ====================
# Comma-separated list of allowed origins for CORS
# For development:
# - Web: http://localhost:5173
# - For production, add your deployment URLs
ALLOWED_ORIGINS=http://localhost:5173,https://gramvartha.vercel.app

# ==================== FIREBASE (Push Notifications) ====================
# Download your Firebase service account JSON from Firebase Console
# Path to the JSON file with Firebase Admin SDK credentials
FIREBASE_SERVICE_ACCOUNT_PATH=gramvartha-0d3028ac535a.json

# ==================== CLOUDINARY (Image Upload) ====================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==================== GOOGLE VISION API ====================
# Path to Google Cloud Vision API service account JSON
GOOGLE_APPLICATION_CREDENTIALS=path/to/google-credentials.json

# ==================== JWT ====================
JWT_SECRET=your_jwt_secret_key_here_min_32_characters

# ==================== SESSION ====================
SESSION_SECRET=your_session_secret_key_here

# ==================== EMAIL (Optional) ====================
# Notification service email configuration
NOTIFICATION_EMAIL_SERVER=smtp.gmail.com
NOTIFICATION_EMAIL_PORT=587
NOTIFICATION_EMAIL_USER=your_email@gmail.com
NOTIFICATION_EMAIL_PASSWORD=your_app_password
